<Window x:Class="VirtualDisplayManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virtual Display Manager" Width="1420" Height="900" MinWidth="1050" MinHeight="720"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="210" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="8" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Virtual Display Manager" FontSize="25" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Text="Driver: VirtualDrivers/Virtual-Display-Driver · 공식 Release 자동 다운로드" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock x:Name="AdminStatusText" />
                    </Border>
                    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4" Padding="10,5">
                        <TextBlock x:Name="DriverStatusText" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="드라이버 상태 및 패키지">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="165" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="드라이버 패키지" />
                    <TextBlock x:Name="PackagePathText" Grid.Column="1" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="1" Text="감지된 INF" Margin="0,6,0,0" />
                    <ComboBox x:Name="InfComboBox" Grid.Row="1" Grid.Column="1" Height="26" Margin="0,5,0,0"
                              DisplayMemberPath="FileName" SelectionChanged="InfComboBox_SelectionChanged" />
                    <TextBlock Grid.Row="2" Text="VDD 장치" Margin="0,6,0,0" />
                    <TextBlock x:Name="DeviceStatusText" Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Text="설정 파일" Margin="0,6,0,0" />
                    <TextBlock x:Name="SettingsPathText" Grid.Row="3" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="4" Text="VDD 추정 모니터" Margin="0,6,0,0" />
                    <TextBlock x:Name="VddMonitorText" Grid.Row="4" Grid.Column="1" Margin="0,6,0,0" />
                    <TextBlock Grid.Row="5" Text="재부팅 필요" Margin="0,6,0,0" />
                    <TextBlock x:Name="RebootStatusText" Grid.Row="5" Grid.Column="1" Margin="0,6,0,0" Text="아니요" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="작업 및 설정" Margin="0,0,0,10">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,10">
                        <Button x:Name="ElevateButton" Content="관리자 권한으로 다시 실행" Click="ElevateButton_Click" />
                        <Button x:Name="CreateVirtualMonitorButton" Content="가상 모니터 만들기" Click="CreateVirtualMonitorButton_Click" />
                        <Button x:Name="InstallButton" Content="드라이버 설치만" Click="InstallButton_Click" />
                        <Button x:Name="UninstallButton" Content="드라이버 삭제" Click="UninstallButton_Click" />
                        <Button x:Name="RecoverDisplayButton" Content="물리 모니터 주 화면(F11)" Click="RecoverDisplayButton_Click" />
                        <Button x:Name="SwitchPrimaryButton" Content="주 화면 전환(F12)" Click="SwitchPrimaryButton_Click" />
                        <Button x:Name="RefreshButton" Content="디스플레이 새로고침" Click="RefreshButton_Click" />
                    </WrapPanel>
                    <WrapPanel Margin="0,0,0,10" VerticalAlignment="Center">
                        <TextBlock Text="개수" VerticalAlignment="Center" Margin="0,0,7,0" />
                        <TextBox x:Name="MonitorCountBox" Width="42" Text="1" />
                        <TextBlock Text="해상도" VerticalAlignment="Center" Margin="14,0,7,0" />
                        <TextBox x:Name="WidthBox" Width="60" Text="1920" />
                        <TextBlock Text="x" VerticalAlignment="Center" Margin="5,0" />
                        <TextBox x:Name="HeightBox" Width="60" Text="1080" />
                        <TextBlock Text="Hz" VerticalAlignment="Center" Margin="14,0,7,0" />
                        <TextBox x:Name="RefreshRateBox" Width="50" Text="60" />
                    </WrapPanel>
                    <TextBlock Margin="0,0,0,8" Text="F11: 물리 모니터를 주 화면으로 지정 · F12: 확장 상태 유지 후 주 화면만 다음 모니터로 전환" TextWrapping="Wrap" />
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="FPS 제한" VerticalAlignment="Center" Margin="0,0,7,0" />
                        <ComboBox x:Name="FpsComboBox" Width="72" SelectedIndex="2" SelectionChanged="FpsComboBox_SelectionChanged">
                            <ComboBoxItem Content="5" /><ComboBoxItem Content="10" /><ComboBoxItem Content="15" />
                            <ComboBoxItem Content="30" /><ComboBoxItem Content="60" />
                        </ComboBox>
                        <TextBlock Text="미리보기 스케일" VerticalAlignment="Center" Margin="14,0,7,0" />
                        <ComboBox x:Name="ScaleComboBox" Width="85" SelectedIndex="1" SelectionChanged="ScaleComboBox_SelectionChanged">
                            <ComboBoxItem Content="25%" Tag="0.25" /><ComboBoxItem Content="50%" Tag="0.5" />
                            <ComboBoxItem Content="75%" Tag="0.75" /><ComboBoxItem Content="100%" Tag="1.0" />
                        </ComboBox>
                        <CheckBox x:Name="AutoRefreshCheckBox" Content="자동 새로고침" Margin="14,0,0,0"
                                  VerticalAlignment="Center" Checked="AutoRefreshCheckBox_Changed" Unchecked="AutoRefreshCheckBox_Changed" />
                    </WrapPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>
            <GroupBox Header="감지된 모니터 — 캡처할 행을 먼저 선택하세요">
                <DataGrid x:Name="MonitorGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" SelectionChanged="MonitorGrid_SelectionChanged"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="장치" Binding="{Binding DeviceName}" Width="110" />
                        <DataGridTextColumn Header="좌표" Binding="{Binding Position}" Width="90" />
                        <DataGridTextColumn Header="해상도" Binding="{Binding Resolution}" Width="105" />
                        <DataGridTextColumn Header="주" Binding="{Binding PrimaryText}" Width="42" />
                        <DataGridTextColumn Header="유형" Binding="{Binding VddText}" Width="80" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="선택한 모니터 미리보기" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button x:Name="StartPreviewButton" Content="미리보기 시작" Click="StartPreviewButton_Click" />
                            <Button x:Name="OpenPreviewWindowButton" Content="새 창 미리보기" IsEnabled="False" Click="OpenPreviewWindowButton_Click" />
                            <Button x:Name="StopPreviewButton" Content="미리보기 중지" IsEnabled="False" Click="StopPreviewButton_Click" />
                        </StackPanel>
                        <TextBlock x:Name="PreviewStatusText" Text="중지됨 · 모니터를 선택하세요" VerticalAlignment="Center" />
                    </DockPanel>
                    <Border Grid.Row="1" BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <TextBlock x:Name="PreviewPlaceholder" Text="화면은 자동으로 캡처되지 않습니다.&#10;대상을 선택한 뒤 ‘미리보기 시작’을 누르세요."
                                       TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Image x:Name="PreviewImage" Stretch="Uniform" SnapsToDevicePixels="True" />
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="3" Header="작업 로그" Margin="0">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas" FontSize="12" />
        </GroupBox>
    </Grid>
</Window>
